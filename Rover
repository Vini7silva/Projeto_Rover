void setup() {
  Serial.begin(115200);
  int p[] = {1, 2, 4, 5, 6, 7, 15, 16};
  for(int i=0; i<8; i++) pinMode(p[i], OUTPUT);

  // Configuração IP ESTÁTICO (Crítico para o App Inventor)
  IPAddress local_ip(192, 168, 4, 1);
  IPAddress gateway(192, 168, 4, 1);
  IPAddress subnet(255, 255, 255, 0);
  WiFi.softAPConfig(local_ip, gateway, subnet);

  WiFi.softAP(ssid, password);
  Serial.print("IP do Rover: "); Serial.println(WiFi.softAPIP());

  // Rotas de Comando
  server.on("/", []() { server.send(200, "text/html", index_html); });
  server.on("/F", []() { mover(1,0,1,0,1,0,1,0); server.send(200); });
  server.on("/B", []() { mover(0,1,0,1,0,1,0,1); server.send(200); });
  server.on("/L", []() { mover(0,1,1,0,1,0,0,1); server.send(200); });
  server.on("/R", []() { mover(1,0,0,1,0,1,1,0); server.send(200); });
  server.on("/S", []() { mover(0,0,0,0,0,0,0,0); server.send(200); });
  server.on("/X", []() { mover(0,1,0,1,1,0,1,0); server.send(200); }); // Lateral Esquerda
  server.on("/Z", []() { mover(1,0,1,0,0,1,0,1); server.send(200); }); // Lateral Direita

  server.begin();
}

void loop() {
  server.handleClient();
}
