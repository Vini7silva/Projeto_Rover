#include <WiFi.h>
#include <WebServer.h>

// Configurações do WiFi (O ESP32 criará esta rede)
const char* ssid = "CARRO_ESP32_S3";
const char* password = "123456789";

WebServer server(80);

// --- PINAGEM ESP32-S3 ---
const int M1_AIN1 = 1;  const int M1_AIN2 = 2;  
const int M3_BIN1 = 4;  const int M3_BIN2 = 5;  
const int M2_AIN1 = 6;  const int M2_AIN2 = 7;  
const int M4_BIN1 = 15; const int M4_BIN2 = 16;

void mover(int m1a, int m1b, int m2a, int m2b, int m3a, int m3b, int m4a, int m4b) {
  digitalWrite(M1_AIN1, m1a); digitalWrite(M1_AIN2, m1b);
  digitalWrite(M2_AIN1, m2a); digitalWrite(M2_AIN2, m2b);
  digitalWrite(M3_BIN1, m3a); digitalWrite(M3_BIN2, m3b);
  digitalWrite(M4_BIN1, m4a); digitalWrite(M4_BIN2, m4b);
}

// Interface HTML para controlo via Browser (Landscape)
const char index_html[] PROGMEM = R"rawliteral(
